{
  "name": "cfrelaytun",
  "version": "0.1.0",
  "description": "Self-hosted ngrok-style HTTP tunnel on Cloudflare Workers + Durable Objects.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "wrangler.example.jsonc",
    "README.md",
    "LICENSE"
