  "scripts": {
    "build": "tsc --noEmit",
    "deploy:example": "wrangler deploy --config example/wrangler.jsonc"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "hono": "^4.0.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.0.0"
  }
}
