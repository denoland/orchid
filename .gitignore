.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example
.env
.env.*
!.env.example
wrangler.jsonc

# Frontend (vite/npm)
www/node_modules/
www/dist/
www/.cache/
internal/orch/embed-dist/

# Relay (CF Worker)
relay/node_modules/
relay/.wrangler/
relay/.dev.vars
relay/.dev.vars.*
relay/dist/
# Built dashboard SPA is generated by `cd www && npm run build` and copied
# into relay/public/ at deploy time; keep relay/public/ source-controlled
# only for the landing page + favicon. Build artefacts:
relay/public/_a/
relay/public/index.html

